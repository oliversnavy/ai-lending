results/skills/
results/traces/
results/episode_indexes/*.jsonl

# Pilot archive is committed for paper reference; exclude large binary outputs only
results/pilots/**/*.parquet

# vLLM build artifacts
vllm-install/

# Jupyter checkpoints
.ipynb_checkpoints/
notebooks/.ipynb_checkpoints/

# Environment
.env
.env.*

# Agent-generated artifacts (written to project root by T1+ agents)
pipeline.py

